# ── Configuration SMTP (alertes email) ──────────────────────────────────────
# Copier ce fichier en .env et remplir les valeurs réelles.
# Ne jamais committer le fichier .env dans git.

# Serveur SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Identifiants SMTP
# Pour Gmail : utiliser un "mot de passe d'application" (pas le mot de passe du compte)
# https://myaccount.google.com/apppasswords
SMTP_USER=votre.email@gmail.com
SMTP_PASS=xxxx_xxxx_xxxx_xxxx
